NODE_ENV=development
PORT=4000
CORS_ORIGIN=https://morev.neeklo.ru
DATABASE_URL=postgresql://fam_user:CHANGEME@localhost:5432/fam_anapa?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=CHANGEME_64_BYTES
JWT_REFRESH_SECRET=CHANGEME_64_BYTES
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Notifications (Этап 5: BullMQ + Redis). В админке: /admin/settings/notifications —
# туда сохраняются токен бота (setWebhook автоматически), HTTPS publicAppUrl и URL исходящего webhook.
# Webhook входящих обновлений Telegram: https://ВАШ_ДОМЕН/api/integrations/telegram/webhook (+ secret из БД в заголовке X-Telegram-Bot-Api-Secret-Token).
ADMIN_PUBLIC_BASE_URL=https://morev.neeklo.ru
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# POST JSON { event: "lead.created", lead: { ... } } — запасной вариант если не задано в админке
LEAD_NOTIFICATION_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Администраторы: копии о новых заявках на email (несколько через запятую)
LEAD_NOTIFICATION_EMAIL_TO=
# Для локального SMTP без STARTTLS — при необходимости (на проде не задавать)
SMTP_IGNORE_TLS=

# MAX messager (platform-api.max.ru). Токен в админке /admin/settings/notifications; fallback:
MAX_BOT_ACCESS_TOKEN=
# Входящий webhook после подписки: https://ВАШ_ДОМЕН/api/integrations/max/webhook (секрет — X-Max-Bot-Api-Secret).

# Публичные мутации без сессии (заявки, аналитика, RAG retrieve) CSRF не требуют.

# База знаний / RAG (Этап 8): эмбеддинги через OpenAI (text-embedding-3-small), опционально
OPENAI_API_KEY=
