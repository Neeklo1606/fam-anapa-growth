NODE_ENV=development
PORT=4000
CORS_ORIGIN=https://morev.neeklo.ru
DATABASE_URL=postgresql://fam_user:CHANGEME@localhost:5432/fam_anapa?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=CHANGEME_64_BYTES
JWT_REFRESH_SECRET=CHANGEME_64_BYTES
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Notifications (Этап 5: BullMQ + Redis). В админке: /admin/settings/notifications —
# туда сохраняются токен бота (setWebhook автоматически), HTTPS publicAppUrl и URL исходящего webhook.
# Webhook входящих обновлений Telegram: https://ВАШ_ДОМЕН/api/integrations/telegram/webhook (+ secret из БД в заголовке X-Telegram-Bot-Api-Secret-Token).
ADMIN_PUBLIC_BASE_URL=https://morev.neeklo.ru
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# POST JSON { event: "lead.created", lead: { ... } } — запасной вариант если не задано в админке
LEAD_NOTIFICATION_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
